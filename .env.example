# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# See docs/ARCHITECTURE.md#environment-configuration for what each group is
# used for and where to find the values in the Supabase dashboard.

# --- Database (Supabase Postgres) ------------------------------------------

# Pooled connection (Supavisor/PgBouncer, port 6543) — used by the app at
# runtime via the Prisma driver adapter. Supabase dashboard: Project Settings
# > Database > Connection string > "Transaction" mode.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used only by the Prisma CLI (migrate, db
# push, studio) via prisma.config.ts. Same dashboard page, "Session" mode.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- Supabase project --------------------------------------------------------

# Project Settings > API. Safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."

# Project Settings > API > service_role. Server-only — bypasses Row Level
# Security. Never prefix this with NEXT_PUBLIC_ or use it in a Client
# Component.
SUPABASE_SERVICE_ROLE_KEY="ey..."

# --- AI (Vercel AI Gateway) --------------------------------------------------

# vercel.com/[team]/~/ai-gateway/api-keys. All LLM calls (resume parsing,
# ATS scoring, etc.) route through the Gateway — see src/lib/ai/client.ts.
AI_GATEWAY_API_KEY="..."

# --- AI Router (optional, direct-provider — src/lib/ai/router.ts) -----------
#
# A separate system from the Gateway above — not required by anything yet.
# Leave all of these unset/blank unless a feature explicitly calls
# `generateText`/`generateObject`/`streamText` from "@/lib/ai". Set
# AI_PROVIDER to whichever one you've configured a key for; the others can
# stay blank.
AI_PROVIDER="" # nvidia | groq | gemini | openrouter
NVIDIA_API_KEY=""     # build.nvidia.com
GROQ_API_KEY=""       # console.groq.com/keys
GEMINI_API_KEY=""     # aistudio.google.com/apikey
OPENROUTER_API_KEY="" # openrouter.ai/keys

# --- App ---------------------------------------------------------------------

# Canonical origin, used to build auth redirect/callback URLs. Update for
# each deployed environment (staging/production).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
